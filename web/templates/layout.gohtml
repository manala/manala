<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{{ block "title" . }}Manala{{ end }}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    </head>
    <body class="bg-light">
        <div class="container-md py-3">
            <header class="mb-4 border-bottom">
                <nav class="navbar">
                    <div class="container-fluid">
                        <a class="navbar-brand" href="/">
                            <img src="https://raw.githubusercontent.com/manala/resources/main/logo.svg" height="24" class="d-inline-block align-text-top" alt="Manala">
                            Manala Web UI
                        </a>
                        <form method="get" class="d-flex">
                            <input name="repository" value="{{ .RepositoryUrl }}" placeholder="Repository" class="form-control me-2">
                            <input name="ref" value="{{ .RepositoryRef }}" placeholder="Ref" class="form-control me-2">
                            <button class="btn btn-outline-success" type="submit">Go</button>
                        </form>
                    </div>
                </nav>
            </header>
            <main>
                {{ block "content" . }}{{ end }}
            </main>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    </body>
</html>
