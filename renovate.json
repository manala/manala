{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "labels": ["renovate"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
    },
    {
      "matchDepTypes": ["components"],
      "groupName": "components",
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "dependencies",
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.env$/"],
      "matchStrings": ["MANALA_GO_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "go",
      "depTypeTemplate": "components",
      "datasourceTemplate": "golang-version"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.env$/"],
      "matchStrings": ["MANALA_GORELEASER_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "goreleaser/goreleaser",
      "depTypeTemplate": "components",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.env$/"],
      "matchStrings": ["MANALA_GOLANGCI_LINT_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "golangci/golangci-lint",
      "depTypeTemplate": "components",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.env$/"],
      "matchStrings": ["MANALA_GOTESTSUM_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "gotestyourself/gotestsum",
      "depTypeTemplate": "components",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.env$/"],
      "matchStrings": ["MANALA_ZENSICAL_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "zensical/zensical",
      "depTypeTemplate": "components",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.env$/"],
      "matchStrings": ["MANALA_VHS_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "charmbracelet/vhs",
      "depTypeTemplate": "components",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ]
}
